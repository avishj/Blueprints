set dotenv-load

default:
    @just --list

install:
    bun install --frozen-lockfile

lint:
    bunx astro check
    bunx tsc --noEmit

{% raw %}
test *args:
    bunx vitest run {{ args }}
{% endraw %}

build:
    bunx astro build

dev:
    bunx astro dev

ci:
    just lint
    just test
    just build

clean:
    rm -rf dist/ .astro/ node_modules/ coverage/
