export function setA11yHidden(element: HTMLElement, hidden: boolean): void {
  if (hidden) {
    element.setAttribute("aria-hidden", "true");
    element.inert = true;
    return;
  }

  element.removeAttribute("aria-hidden");
  element.inert = false;
}

export function ensureFocusableVisibility(element: HTMLElement): void {
  const activeElement = document.activeElement;
  if (!activeElement || !element.contains(activeElement)) {
    return;
  }

  element.classList.add("focus-visible:outline", "focus-visible:outline-2", "focus-visible:outline-offset-2");
}
