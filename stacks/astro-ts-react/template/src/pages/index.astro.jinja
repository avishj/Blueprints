---
import App from "@components/App";
import MotionDemo from "@components/motion/MotionDemo";
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout>
  <main class="mx-auto flex min-h-screen w-full max-w-5xl flex-col items-start justify-center gap-8 px-6 py-16 sm:px-10">
    <p class="text-sm uppercase tracking-[0.18em] text-muted">Astro + React + TypeScript + Bun</p>
    <h1 class="text-4xl font-semibold leading-tight sm:text-5xl">{{ project_name }}</h1>
    <p class="max-w-2xl text-base text-muted sm:text-lg">{{ description }}</p>

    <App client:load projectName="{{ project_name }}" />

    {% if include_motion_demo %}
    <MotionDemo client:load />
    {% endif %}
  </main>
</BaseLayout>
