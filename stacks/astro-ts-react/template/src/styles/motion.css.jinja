:root {
  --motion-duration-fast: 160ms;
  --motion-duration-base: 280ms;
  --motion-duration-slow: 420ms;
  --motion-ease-standard: cubic-bezier(0.22, 1, 0.36, 1);
  --motion-ease-emphasize: cubic-bezier(0.16, 1, 0.3, 1);
}

.motion-fade-in {
  animation: motion-fade-in var(--motion-duration-base) var(--motion-ease-standard) both;
}

.motion-lift-in {
  animation: motion-lift-in var(--motion-duration-base) var(--motion-ease-emphasize) both;
}

@keyframes motion-fade-in {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

@keyframes motion-lift-in {
  from {
    opacity: 0;
    transform: translate3d(0, 16px, 0);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 1ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 1ms !important;
    scroll-behavior: auto !important;
  }
}
