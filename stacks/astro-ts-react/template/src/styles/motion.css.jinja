:root {
{% if motion_profile == "minimal" -%}
  --motion-duration-fast: 120ms;
  --motion-duration-base: 200ms;
  --motion-duration-slow: 280ms;
  --motion-ease-standard: cubic-bezier(0.2, 0.8, 0.2, 1);
  --motion-ease-emphasize: cubic-bezier(0.2, 0.9, 0.2, 1);
{% elif motion_profile == "cinematic" -%}
  --motion-duration-fast: 240ms;
  --motion-duration-base: 400ms;
  --motion-duration-slow: 640ms;
  --motion-ease-standard: cubic-bezier(0.16, 1, 0.3, 1);
  --motion-ease-emphasize: cubic-bezier(0.05, 0.9, 0.1, 1);
{% else -%}
  --motion-duration-fast: 160ms;
  --motion-duration-base: 280ms;
  --motion-duration-slow: 420ms;
  --motion-ease-standard: cubic-bezier(0.22, 1, 0.36, 1);
  --motion-ease-emphasize: cubic-bezier(0.16, 1, 0.3, 1);
{% endif -%}
}

.motion-fade-in {
  animation: motion-fade-in var(--motion-duration-base) var(--motion-ease-standard) both;
}

.motion-lift-in {
  animation: motion-lift-in var(--motion-duration-base) var(--motion-ease-emphasize) both;
}

@keyframes motion-fade-in {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

@keyframes motion-lift-in {
  from {
    opacity: 0;
    transform: translate3d(0, 16px, 0);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 1ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 1ms !important;
    scroll-behavior: auto !important;
  }
}
