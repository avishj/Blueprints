@import "tailwindcss";

@theme {
  --font-sans: "Inter", "SF Pro Text", "Segoe UI", Roboto, "Helvetica Neue", Arial, system-ui, sans-serif;
  --color-bg: oklch(0.16 0.02 260);
  --color-fg: oklch(0.97 0.01 250);
  --color-muted: oklch(0.72 0.03 255);
  --color-accent: oklch(0.82 0.14 175);
}

:root {
  color-scheme: dark;
}

* {
  box-sizing: border-box;
}

body {
  @apply bg-bg text-fg antialiased;
  margin: 0;
  min-height: 100vh;
  font-family: var(--font-sans);
}

a {
  color: var(--color-accent);
}
