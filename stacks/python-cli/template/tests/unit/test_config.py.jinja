"""Unit tests for application configuration."""

import pytest

from {{ module_name }}.config import Settings

pytestmark = pytest.mark.unit


def test_defaults(monkeypatch, tmp_path):
    monkeypatch.chdir(tmp_path)
    monkeypatch.delenv("{{ env_prefix }}VERBOSE", raising=False)
    s = Settings()
    assert s.verbose is False


def test_env_prefix(monkeypatch, tmp_path):
    monkeypatch.chdir(tmp_path)
    monkeypatch.setenv("{{ env_prefix }}VERBOSE", "1")
    s = Settings()
    assert s.verbose is True


def test_env_without_prefix_ignored(monkeypatch, tmp_path):
    monkeypatch.chdir(tmp_path)
    monkeypatch.delenv("{{ env_prefix }}VERBOSE", raising=False)
    monkeypatch.setenv("VERBOSE", "true")
    s = Settings()
    assert s.verbose is False
