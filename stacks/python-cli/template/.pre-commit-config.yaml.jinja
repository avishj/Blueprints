---
default_install_hook_types: [pre-commit, commit-msg]
default_language_version:
  python: python3.13

repos:
  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: 3e8a8703264a2f4a69428a0aa4dcb512790b2c8c  # v6.0.0
    hooks:
      # --- File hygiene (checks) ---
      - id: check-added-large-files
        args: [--maxkb=500]
      - id: check-case-conflict
      - id: check-merge-conflict
      - id: check-toml
      - id: check-yaml
        args: [--allow-multiple-documents]
      - id: check-json
      - id: check-symlinks
      - id: check-illegal-windows-names
      - id: check-vcs-permalinks
        exclude: pyproject\.toml
      - id: destroyed-symlinks
      - id: detect-private-key
      # --- File hygiene (fixers) ---
      - id: end-of-file-fixer
      - id: fix-byte-order-marker
      - id: mixed-line-ending
        args: [--fix=lf]
      - id: trailing-whitespace
        args: [--markdown-linebreak-ext=md]
      # --- Branch protection ---
      - id: no-commit-to-branch
        args: [--branch=main]

  # --- Linting & formatting ---
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: d1b833175a5d08a925900115526febd8fe71c98e  # v0.15.11
    hooks:
      - id: ruff
        args: [--fix, --exit-non-zero-on-fix]
      - id: ruff-format

  - repo: https://github.com/adrienverge/yamllint
    rev: cba56bcde1fdd01c1deb3f945e69764c291a6530  # v1.38.0
    hooks:
      - id: yamllint
        args: [-d, '{extends: default, rules: {line-length: disable, truthy: disable}}']

  - repo: https://github.com/crate-ci/typos
    rev: cf5f1c29a8ac336af8568821ec41919923b05a83  # v1.45.1
    hooks:
      - id: typos

  # --- Validation & analysis ---
  - repo: local
    hooks:
      - id: uv-lock-check
        name: uv lock check
        entry: uv lock --check
        language: system
        files: ^(pyproject\.toml|uv\.lock)$
        pass_filenames: false
      - id: ty
        name: ty check
        entry: uv run ty check src/ tests/
        language: system
        types: [python]
        pass_filenames: false

  - repo: https://github.com/abravalheri/validate-pyproject
    rev: 4b2e70d08cb2ccd26d1fba73588de41c7a5d50b7  # v0.25
    hooks:
      - id: validate-pyproject

  - repo: https://github.com/rohaquinlop/complexipy-pre-commit
    rev: 8fe242b9a4c977ceaaed057e3851f4b2ff54e69b  # v5.1.0
    hooks:
      - id: complexipy
        args: [--max-complexity-allowed, "15"]

  # --- Commit hygiene ---
  - repo: https://github.com/commitizen-tools/commitizen
    rev: 2ca29f9297911f8f5a4e8f97100b7832f045e8d3  # v4.13.10
    hooks:
      - id: commitizen

  # --- Security & licensing ---
  - repo: https://github.com/gitleaks/gitleaks
    rev: 83d9cd684c87d95d656c1458ef04895a7f1cbd8e  # v8.30.1
    hooks:
      - id: gitleaks

  - repo: https://github.com/fsfe/reuse-tool
    rev: a1bb792acda6fd0724936b4ebbdbc8eceb9c0459  # v6.2.0
    hooks:
      - id: reuse
