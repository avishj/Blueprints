[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ project_name }}"
version = "0.0.1"
description = "{{ description }}"
readme = "README.md"
license = "AGPL-3.0-or-later"
requires-python = ">=3.13"
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
keywords = []
classifiers = [
    "Development Status :: 3 - Alpha",
    "Environment :: Console",
    "Intended Audience :: Developers",
    "License :: OSI Approved :: GNU Affero General Public License v3 or later (AGPLv3+)",
    "Operating System :: OS Independent",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3.13",
    "Programming Language :: Python :: 3.14",
    "Typing :: Typed",
]
dependencies = [
    "cyclopts>=4.10.1",
    "pydantic-settings>=2.13.1",
    "rich>=14.3.3",
]

[project.scripts]
{{ project_name }} = "{{ module_name }}.cli:entrypoint"

[project.urls]
Homepage = "https://github.com/{{ owner }}/{{ project_name }}"
Documentation = "https://{{ owner }}.github.io/{{ project_name }}"
Repository = "https://github.com/{{ owner }}/{{ project_name }}"
Changelog = "https://github.com/{{ owner }}/{{ project_name }}/blob/main/CHANGELOG.md"
Issues = "https://github.com/{{ owner }}/{{ project_name }}/issues"

[dependency-groups]
dev = [
    "commitizen>=4.13.9",
    "complexipy>=5.2.0",
    "mkdocstrings-python>=2.0.3",
    "pre-commit>=4.5.1",
    "pytest>=9.0.2",
    "pytest-cov>=7.1.0",
    "pytest-github-actions-annotate-failures>=0.4.0",
    "pytest-mock>=3.15.1",
    "pytest-randomly>=4.0.1",
    "pytest-timeout>=2.4.0",
    "pytest-xdist>=3.8.0",
    "ruff>=0.15.8",
    "ty>=0.0.27",
    "zensical>=0.0.31",
]

[tool.hatch.build.targets.wheel]
packages = ["src/{{ module_name }}"]

[tool.uv]
python-preference = "managed"

[tool.ruff]
src = ["src", "tests"]

[tool.ruff.lint]
select = ["ALL"]
ignore = [
    "COM812", # conflicts with formatter
    "ISC001", # conflicts with formatter
]

[tool.ruff.lint.isort]
known-first-party = ["{{ module_name }}"]

[tool.ruff.lint.pydocstyle]
convention = "google"

[tool.ruff.lint.per-file-ignores]
"tests/**/*.py" = [
    "S101",   # assert allowed in tests
    "ANN",    # annotations not required in tests
    "D",      # docstrings not required in tests
    "ARG",    # unused arguments (fixtures)
    "PLR2004", # magic values in tests
    "FBT",    # boolean traps in tests
]
"tests/e2e/*.py" = [
    "S603",   # subprocess.run is intentional in CLI end-to-end tests
    "S607",   # console scripts from PATH are intentional in CLI end-to-end tests
]

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["src"]
addopts = [
    "--strict-markers",
    "--strict-config",
    "-ra",
]
markers = [
    "unit: fast isolated tests with no external dependencies",
    "integration: tests exercising multiple components together (e.g. CliRunner)",
    "e2e: end-to-end tests invoking the installed CLI via subprocess",
]
timeout = 60
filterwarnings = ["error"]
xfail_strict = true

[tool.coverage.run]
source = ["{{ module_name }}"]
branch = true
core = ctrace
parallel = true
relative_files = true
patch = ["subprocess"]

[tool.coverage.report]
fail_under = 70
show_missing = true
skip_empty = true
exclude_also = [
    "@overload",
    "if __name__ == .__main__.:",
    "raise NotImplementedError",
]

[tool.commitizen]
version = "0.0.1"
tag_format = "v$version"
version_files = [
    "pyproject.toml:version",
]
update_changelog_on_bump = true
