root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
indent_size = unset
trim_trailing_whitespace = false

[*.toml]
indent_size = 4

[LICENSE]
indent_size = unset
